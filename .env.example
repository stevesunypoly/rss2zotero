# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — it is listed in .gitignore.

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Zotero API key — https://www.zotero.org/settings/keys/new
# Grant "Write" access to the group library configured in config.yaml.
ZOTERO_API_KEY=your_zotero_api_key_here

# SMTP password — only needed if you add email delivery to config.yaml
# SMTP_PASSWORD=your_smtp_password_here
